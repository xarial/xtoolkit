<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Xarial.XToolkit.Wpf.Converters"
                    xmlns:local="clr-namespace:Xarial.XToolkit.Wpf.Controls">

    <conv:ObjectIsNotNullVisibilityConverter x:Key="objIsNotNullToVisConv"/>
    
    <Style TargetType="{x:Type local:ColorPicker}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ColorPicker}">
                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Background="{TemplateBinding Color}" x:Name="PART_MainGrid" VerticalAlignment="Stretch">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" Margin="2"
                                           TextTrimming="CharacterEllipsis">
                                    <Hyperlink x:Name="PART_SelectColorLink">
                                        <TextBlock x:Name="PART_ColorTextBlock" VerticalAlignment="Center"/>
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Margin="2" VerticalAlignment="Center"
                                           ToolTip="{TemplateBinding RemoveColorButtonTooltip}"
                                           Visibility="{TemplateBinding Color, Converter={StaticResource objIsNotNullToVisConv}}">
                                    <Hyperlink x:Name="PART_RemoveColorLink" TextDecorations="">
                                        <TextBlock Text="&#10060;" VerticalAlignment="Center"/>
                                    </Hyperlink>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>